{
  "name": "astra",
  "description": "ASTRA - Shop Management System",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install && cd ../database && npm install && cd ..",
    "dev": "npm run dev:all",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:all": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run start",
    "build:frontend": "cd frontend && npm run build",
    "db:migrate": "cd database && npm run migrate",
    "db:studio": "cd database && npm run studio"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "backend",
    "frontend",
    "database"
  ]
}
