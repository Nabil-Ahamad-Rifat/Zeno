# Database (MongoDB)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/zeno?retryWrites=true&w=majority&appName=Cluster0

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Admin Seeding
ADMIN_EMAIL=admin@zeno.com
ADMIN_PASSWORD=Admin@123456

# OAuth Token Encryption (crypto-js)
OAUTH_TOKEN_ENCRYPTION_KEY=your_32_character_encryption_key_minimum_32

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# OAuth Callback URLs (adjust domain in production)
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/oauth/google/callback
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/v1/oauth/facebook/callback
LINKEDIN_CALLBACK_URL=http://localhost:4000/api/v1/oauth/linkedin/callback

# Email (Gmail SMTP for memos)
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Shop
SHOP_NAME=Your Shop Name
SHOP_EMAIL=shop@example.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Session Secret (for express-session OAuth state)
SESSION_SECRET=your_super_secret_session_key_change_this_in_production
