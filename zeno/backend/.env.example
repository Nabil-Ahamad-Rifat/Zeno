# Database
DATABASE_URL="mysql://root:password@localhost:3306/astra_db"

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Admin Auth (hardcoded for now)
