---
const links = [
  { href: '/dashboard', label: 'Dashboard' },
  { href: '/customers', label: 'Customers' },
  { href: '/products', label: 'Products' },
  { href: '/sales/new', label: 'New Sale' },
  { href: '/sales', label: 'History' },
  { href: '/reports', label: 'Reports' },
]
const current = Astro.url.pathname
---

<nav class="bg-blue-600 text-white shadow-md">
  <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
    <h1 class="text-2xl font-bold tracking-wide">ZENO</h1>

    <div class="flex items-center gap-1">
      {links.map(link => (
        <a
          href={link.href}
          class={`px-3 py-2 rounded text-sm font-medium transition-colors ${
            current.startsWith(link.href) && (current === link.href || link.href !== '/sales/new')
              ? 'bg-blue-800 text-white'
              : 'text-blue-100 hover:bg-blue-700 hover:text-white'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <!-- CMS button: shown only for admin via JS -->
      <a
        id="cms-link"
        href="/keystatic"
        class="hidden items-center gap-1.5 px-3 py-1.5 bg-blue-500 hover:bg-blue-400 border border-blue-400 rounded text-xs font-semibold text-white transition-colors"
        title="Content Management"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
        CMS
      </a>

      <button
        id="logout-btn"
        class="px-4 py-2 bg-blue-700 hover:bg-blue-800 rounded text-sm font-medium"
      >
        Logout
      </button>
    </div>
  </div>
</nav>

<script>
  import { logout } from '../stores/auth.js'
  document.getElementById('logout-btn').addEventListener('click', logout)

  // Show CMS link only for admin
  const user = JSON.parse(localStorage.getItem('user') || 'null')
  if (user?.role === 'admin') {
    const cmsLink = document.getElementById('cms-link')
    cmsLink?.classList.remove('hidden')
    cmsLink?.classList.add('flex')
  }
</script>
