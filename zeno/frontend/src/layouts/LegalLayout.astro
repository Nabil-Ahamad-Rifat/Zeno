---
const { title, lastUpdated } = Astro.props
const formatted = lastUpdated
  ? new Date(lastUpdated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title} — ZENO</title>
  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <a href="/" class="text-blue-600 text-sm hover:underline mb-8 inline-block">← Back to ZENO</a>
    <h1 class="text-4xl font-bold text-gray-900 mt-4 mb-2">{title}</h1>
    {formatted && (
      <p class="text-sm text-gray-400 mb-8">Last updated: {formatted}</p>
    )}
    <div class="prose prose-gray max-w-none text-gray-700 leading-relaxed">
      <slot />
    </div>
  </div>
</body>
</html>
