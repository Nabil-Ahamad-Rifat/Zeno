---
export const prerender = true
import { createReader } from '@keystatic/core/reader'
import config from '../../keystatic.config'
import LegalLayout from '../layouts/LegalLayout.astro'
import Markdoc from '@markdoc/markdoc'

const reader = createReader(process.cwd(), config)
const page = await reader.singletons.refund.read()
if (!page) throw new Error('Refund content not found')

const { node } = await page.content()
const html = Markdoc.renderers.html(node)
---
<LegalLayout title={page.title} lastUpdated={page.lastUpdated}>
  <Fragment set:html={html} />
</LegalLayout>
